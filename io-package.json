    "news": {
      "5.3.2": {
        "en": "Fixed vis-2.0 widget not displaying on initial page load\nAdded retry mechanism with StateManager\nImproved error handling",
        "de": "Behoben: vis-2.0 Widget wird nicht beim initialen Seitenladen angezeigt\nRetry-Mechanismus mit StateManager hinzugefügt\nFehlerbehandlung verbessert"
      },
      "5.3.1": {
        "en": "Added native vis-2.0 widget support with Vue 3",
        "de": "Nativer vis-2.0 Widget Support mit Vue 3 hinzugefügt"
      },
      "5.3.0": {
        "en": "Fixed filtering of Lobbe.app address selections in the admin UI\nAdded Lobbe.app as a new data source\nAdded German labels for the Lobbe address selection",
        "de": "Behobene Filterung von Lobbe.app Adressenauswahlen im Admin UI\nLobbe.app als neue Datenquelle hinzugefügt\nDeutsche Labels für die Lobbe Adressenauswahl hinzugefügt"
      },
      "5.2.1": {
        "en": "Fixed responsive config layout on xl screens",
        "de": "Feste ansprechende Konfiguration auf xl Bildschirmen"
      }
    },
    "titleLang": {
      "en": "Trash Schedule",
      "de": "Müllabfuhr-Zeitplan",
      "ru": "Расписание мусора",
      "pt": "Agenda de lixo",
      "nl": "Prullenbak Schema",
      "fr": "Horaire de la corbeille",
      "it": "Programma del cestino",
      "es": "Horario de basura",
      "pl": "Harmonogram śmieci",
      "uk": "Розклад сміття",
      "zh-cn": "垃圾分类"
    },
    "desc": {
      "en": "Calculates the days until next trash pickup",
      "de": "Berechnet die Tage bis zur nächsten Müllabfuhr",
      "ru": "Подсчитывает количество дней до следующего вывоза мусора",
      "pt": "Calcula os dias até a próxima coleta de lixo",
      "nl": "Berekent de dagen tot de volgende ophaling van afval",
      "fr": "Calcule les jours jusqu'au prochain ramassage des ordures",
      "it": "Calcola i giorni fino al prossimo ritiro della spazzatura",
      "es": "Calcula los días hasta la próxima recolección de basura",
      "pl": "Oblicza dni do następnego odbioru śmieci",
      "uk": "Розраховує дні до наступного вивезення сміття",
      "zh-cn": "计算距离下一次垃圾回收的天数"
    },
    "authors": [
      "Matthias Kleine <info@haus-automatisierung.com>"
    ],
    "keywords": [
      "trash",
      "calendar",
      "muell",
      "muellabfuhr"
    ],
    "tier": 3,
    "licenseInformation": {
      "license": "MIT",
      "type": "free"
    },
    "platform": "Javascript/Node.js",
    "icon": "trashschedule.png",
    "extIcon": "https://raw.githubusercontent.com/klein0r/ioBroker.trashschedule/master/admin/trashschedule.png",
    "enabled": true,
    "readme": "https://github.com/klein0r/ioBroker.trashschedule/blob/master/README.md",
    "loglevel": "info",
    "messagebox": true,
    "logTransporter": true,
    "mode": "daemon",
    "type": "date-and-time",
    "compact": true,
    "connectionType": "cloud",
    "dataSource": "poll",
