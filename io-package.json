      {
        "js-controller": ">=6.0.11"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=7.6.20"
      }
    ],
    "plugins": {
      "sentry": {
        "dsn": "https://ae5180dfac964a4d8d1c74657dd14281@sentry.iobroker.net/102"
      }
    }
